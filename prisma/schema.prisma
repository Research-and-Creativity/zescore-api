generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  
}

enum Role {
  STUDENT
  LECTURER
  ADMIN
}

enum ProjectCategory {
  POSTER
  PRODUCT
}

model User {
  id        String   @id
  name      String
  role      Role
  password  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assessments Assessment[]
}

model Team {
  id          String   @id @default(uuid())
  teamName    String   @unique
  boothNumber String   @unique
  password    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assessments Assessment[]
}

model Assessment {
  id         String          @id @default(uuid())
  teamId     String
  voterId    String
  category   ProjectCategory // POSTER atau PRODUCT
  isVoteOnly Boolean         @default(false)

  criteria1  Int?    // mahasiswa: tidak diisi | dosen: nilai poster (0-100)
  criteria2  Int?    // dosen: nilai product (0-100)
  totalScore Float   @default(0.0)

  createdAt DateTime @default(now())

  team  Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  voter User @relation(fields: [voterId], references: [id], onDelete: Cascade)

  // Satu voter hanya bisa menilai satu kategori per tim
  @@unique([teamId, voterId, category])
}
