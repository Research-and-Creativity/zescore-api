{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist-seed",
    "rootDir": "."
  },
  "include": ["prisma/seed.ts"],
  "exclude": ["node_modules", "dist"]
}
